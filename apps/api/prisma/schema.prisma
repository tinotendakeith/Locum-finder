generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  CLINIC
  LOCUM
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  PENDING_APPROVAL
  SUSPENDED
  REJECTED
  DEACTIVATED
}

enum LocumProfileStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SUSPENDED
}

enum ResumeStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ClinicProfileStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  SUSPENDED
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  FILLED
  ARCHIVED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  SHORTLISTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum DocumentOwnerType {
  LOCUM
  CLINIC
  RESUME
}

enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  PROFILE_REVIEW
  CLINIC_REVIEW
  JOB_REVIEW
  APPLICATION_EVENT
  MESSAGE_EVENT
  ADMIN_MESSAGE
  SYSTEM
}

enum WorkMode {
  ONSITE
  HYBRID
  REMOTE
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum DataRightsRequestType {
  ACCESS
  CORRECTION
  DELETION
  OBJECTION
  EXPORT
}

enum DataRightsRequestStatus {
  OPEN
  IN_REVIEW
  COMPLETED
}

model User {
  id                    String                   @id @default(uuid())
  email                 String                   @unique
  phone                 String?
  passwordHash          String
  googleId              String?                  @unique
  role                  UserRole
  accountStatus         AccountStatus            @default(PENDING_VERIFICATION)
  emailVerifiedAt       DateTime?
  lastLoginAt           DateTime?
  acceptedPrivacyNotice Boolean                  @default(false)
  acceptedSensitiveDataUse Boolean               @default(false)
  marketingOptIn        Boolean                  @default(false)
  privacyConsentVersion String?
  privacyConsentedAt    DateTime?
  privacyPreferences    Json?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  locumProfile          LocumProfile?
  clinicProfile         ClinicProfile?
  resumes               Resume[]
  authoredMessages      Message[]
  sentApplications      Application[]            @relation("applicantUser")
  clinicApplications    Application[]            @relation("clinicUser")
  sessions              RefreshSession[]
  notifications         Notification[]
  auditLogs             AuditLog[]               @relation("auditActor")
  passwordResetTokens   PasswordResetToken[]
  emailVerification     EmailVerificationToken[]
  conversationsAsClinic Conversation[]           @relation("conversationClinic")
  conversationsAsLocum  Conversation[]           @relation("conversationApplicant")
  savedJobs             SavedJob[]
  dataRightsRequests    DataRightsRequest[]
}

model DataRightsRequest {
  id          String                  @id @default(uuid())
  userId      String?
  name        String
  email       String
  requestType DataRightsRequestType
  details     String
  status      DataRightsRequestStatus @default(OPEN)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  user        User?                   @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([status, createdAt])
}

model RefreshSession {
  id             String   @id @default(uuid())
  userId         String
  tokenHash      String
  expiresAt      DateTime
  revokedAt      DateTime?
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model Profession {
  id            String   @id @default(uuid())
  name          String   @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  locumProfiles LocumProfile[]
  resumes       Resume[]
  jobs          Job[]
}

model Specialty {
  id           String   @id @default(uuid())
  name         String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  resumes      ResumeSpecialty[]
  jobLinks     JobSpecialty[]
}

model FacilityType {
  id             String   @id @default(uuid())
  name           String   @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  clinicProfiles ClinicProfile[]
}

model Region {
  id         String   @id @default(uuid())
  name       String   @unique
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  locumProfiles  LocumProfile[]
  resumes        Resume[]
  clinicProfiles ClinicProfile[]
  jobs           Job[]
}

model DocumentType {
  id         String     @id @default(uuid())
  code       String     @unique
  name       String
  ownerType  DocumentOwnerType
  required   Boolean    @default(false)
  createdAt  DateTime   @default(now())
  documents  Document[]
}

model LocumProfile {
  id                  String             @id @default(uuid())
  userId              String             @unique
  firstName           String
  lastName            String
  professionalTitle   String?
  professionId        String
  yearsExperience     Int?
  bio                 String?
  licenseNumber       String?
  licenseAuthority    String?
  city                String?
  regionId            String?
  languages           String[]
  expectedRateMin     Decimal?           @db.Decimal(10,2)
  expectedRateMax     Decimal?           @db.Decimal(10,2)
  currency            String?
  workPreferences     String?
  availabilitySummary String?
  phoneNumber         String?
  profilePhotoUrl     String?
  status              LocumProfileStatus @default(DRAFT)
  completenessScore   Int                @default(0)
  submittedAt         DateTime?
  reviewedAt          DateTime?
  reviewedByUserId    String?
  rejectionReason     String?
  adminNotes          String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user                User                 @relation(fields: [userId], references: [id])
  profession          Profession           @relation(fields: [professionId], references: [id])
  region              Region?              @relation(fields: [regionId], references: [id])
  documents           Document[]
}

model Resume {
  id                  String         @id @default(uuid())
  userId              String
  professionId        String?
  regionId            String?
  title               String
  fullName            String
  professionalTitle   String?
  phone               String?
  email               String?
  location            String?
  gender              String?
  dateOfBirth         DateTime?
  summary             String?
  yearsExperience     Int?
  registrationNumber  String?
  availability        String?
  profilePhotoUrl     String?
  isDefault           Boolean        @default(false)
  status              ResumeStatus   @default(DRAFT)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user                User               @relation(fields: [userId], references: [id])
  profession          Profession?        @relation(fields: [professionId], references: [id])
  region              Region?            @relation(fields: [regionId], references: [id])
  specialties         ResumeSpecialty[]
  education           ResumeEducation[]
  experience          ResumeExperience[]
  memberships         ResumeMembership[]
  documents           Document[]
  applications        Application[]

  @@index([userId, status])
}

model ResumeSpecialty {
  resumeId      String
  specialtyId   String

  resume        Resume     @relation(fields: [resumeId], references: [id])
  specialty     Specialty  @relation(fields: [specialtyId], references: [id])

  @@id([resumeId, specialtyId])
}

model ResumeEducation {
  id            String   @id @default(uuid())
  resumeId      String
  institution   String
  qualification String
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())

  resume        Resume   @relation(fields: [resumeId], references: [id])
}

model ResumeExperience {
  id            String   @id @default(uuid())
  resumeId      String
  employer      String
  role          String
  description   String?
  startDate     DateTime?
  endDate       DateTime?
  createdAt     DateTime @default(now())

  resume        Resume   @relation(fields: [resumeId], references: [id])
}

model ResumeMembership {
  id                  String   @id @default(uuid())
  resumeId            String
  associationName     String
  registrationNumber  String?
  verifiedStatus      String?
  createdAt           DateTime @default(now())

  resume              Resume   @relation(fields: [resumeId], references: [id])
}

model ClinicProfile {
  id                       String              @id @default(uuid())
  userId                   String              @unique
  facilityName             String
  facilityTypeId           String?
  description              String?
  addressLine1             String?
  addressLine2             String?
  city                     String?
  regionId                 String?
  website                  String?
  email                    String?
  phoneNumber              String?
  logoUrl                  String?
  bannerUrl                String?
  departments              String[]
  contactPersonName        String?
  contactPersonRole        String?
  contactPersonPhone       String?
  registrationNumber       String?
  operatingLicenseNumber   String?
  staffingPreferences      String?
  status                   ClinicProfileStatus @default(DRAFT)
  submittedAt              DateTime?
  reviewedAt               DateTime?
  reviewedByUserId         String?
  rejectionReason          String?
  adminNotes               String?
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt

  user                     User          @relation(fields: [userId], references: [id])
  facilityType             FacilityType? @relation(fields: [facilityTypeId], references: [id])
  region                   Region?       @relation(fields: [regionId], references: [id])
  jobs                     Job[]
  documents                Document[]
}

model Job {
  id                       String       @id @default(uuid())
  clinicProfileId          String
  professionId             String
  title                    String
  slug                     String?      @unique
  roleLabel                String?
  categoryLabel            String?
  department               String?
  locationText             String?
  city                     String?
  regionId                 String?
  workMode                 WorkMode     @default(ONSITE)
  startDate                DateTime
  endDate                  DateTime?
  shiftDates               DateTime[]
  durationText             String?
  hoursText                String?
  compensationRate         Decimal?     @db.Decimal(10,2)
  currency                 String       @default("USD")
  description              String
  responsibilities         String?
  requirements             String?
  requiredQualifications   String?
  experienceLevel          String?
  applicationDeadline      DateTime?
  urgency                  UrgencyLevel @default(MEDIUM)
  professionalsNeeded      Int          @default(1)
  status                   JobStatus    @default(DRAFT)
  visibilityPublic         Boolean      @default(true)
  adminInternalNotes       String?
  submittedAt              DateTime?
  reviewedAt               DateTime?
  reviewedByUserId         String?
  rejectionReason          String?
  filledAt                 DateTime?
  closedAt                 DateTime?
  archivedAt               DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  clinicProfile            ClinicProfile @relation(fields: [clinicProfileId], references: [id])
  profession               Profession    @relation(fields: [professionId], references: [id])
  region                   Region?       @relation(fields: [regionId], references: [id])
  specialties              JobSpecialty[]
  applications             Application[]
  savedBy                  SavedJob[]
  conversations            Conversation[]

  @@index([status, startDate])
  @@index([professionId, city])
}

model JobSpecialty {
  jobId        String
  specialtyId  String

  job          Job       @relation(fields: [jobId], references: [id])
  specialty    Specialty @relation(fields: [specialtyId], references: [id])

  @@id([jobId, specialtyId])
}

model Application {
  id                     String            @id @default(uuid())
  jobId                  String
  applicantUserId        String
  clinicUserId           String
  resumeId               String
  status                 ApplicationStatus @default(SUBMITTED)
  message                String?
  resumeSnapshotJson     String?
  appliedAt              DateTime          @default(now())
  reviewedAt             DateTime?
  reviewedByClinicUserId String?
  statusReason           String?
  withdrawnAt            DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  job                    Job               @relation(fields: [jobId], references: [id])
  applicantUser          User              @relation("applicantUser", fields: [applicantUserId], references: [id])
  clinicUser             User              @relation("clinicUser", fields: [clinicUserId], references: [id])
  resume                 Resume            @relation(fields: [resumeId], references: [id])
  history                ApplicationHistory[]
  conversation           Conversation?

  @@unique([jobId, applicantUserId])
  @@index([status, appliedAt])
}

model ApplicationHistory {
  id              String             @id @default(uuid())
  applicationId   String
  fromStatus      ApplicationStatus?
  toStatus        ApplicationStatus
  actorUserId     String
  note            String?
  createdAt       DateTime           @default(now())

  application     Application        @relation(fields: [applicationId], references: [id])

  @@index([applicationId, createdAt])
}

model Conversation {
  id               String       @id @default(uuid())
  jobId            String
  applicationId    String       @unique
  clinicUserId     String
  applicantUserId  String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  job              Job          @relation(fields: [jobId], references: [id])
  application      Application  @relation(fields: [applicationId], references: [id])
  clinicUser       User         @relation("conversationClinic", fields: [clinicUserId], references: [id])
  applicantUser    User         @relation("conversationApplicant", fields: [applicantUserId], references: [id])
  messages         Message[]
}

model Message {
  id               String       @id @default(uuid())
  conversationId   String
  senderUserId     String
  body             String
  readAt           DateTime?
  createdAt        DateTime     @default(now())

  conversation     Conversation @relation(fields: [conversationId], references: [id])
  senderUser       User         @relation(fields: [senderUserId], references: [id])

  @@index([conversationId, createdAt])
}

model SavedJob {
  id               String   @id @default(uuid())
  userId           String
  jobId            String
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id])
  job              Job      @relation(fields: [jobId], references: [id])

  @@unique([userId, jobId])
}

model Document {
  id                    String               @id @default(uuid())
  ownerType             DocumentOwnerType
  ownerLocumProfileId   String?
  ownerClinicProfileId  String?
  ownerResumeId         String?
  documentTypeId        String
  fileName              String
  filePath              String
  mimeType              String
  fileSizeBytes         Int
  reviewStatus          DocumentReviewStatus @default(PENDING)
  reviewedByUserId      String?
  reviewedAt            DateTime?
  rejectionReason       String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  ownerLocumProfile     LocumProfile?  @relation(fields: [ownerLocumProfileId], references: [id])
  ownerClinicProfile    ClinicProfile? @relation(fields: [ownerClinicProfileId], references: [id])
  ownerResume           Resume?        @relation(fields: [ownerResumeId], references: [id])
  documentType          DocumentType   @relation(fields: [documentTypeId], references: [id])

  @@index([ownerType, ownerLocumProfileId, ownerClinicProfileId, ownerResumeId])
}

model Notification {
  id            String            @id @default(uuid())
  userId        String
  type          NotificationType
  title         String
  body          String
  actionUrl     String?
  metadataJson  String?
  readAt        DateTime?
  createdAt     DateTime          @default(now())

  user          User              @relation(fields: [userId], references: [id])

  @@index([userId, readAt])
}

model AuditLog {
  id             String   @id @default(uuid())
  actorUserId    String?
  action         String
  entityType     String
  entityId       String?
  metadataJson   String?
  createdAt      DateTime @default(now())

  actor          User?    @relation("auditActor", fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}
