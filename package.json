{
  "name": "locumfinder-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "db:generate": "pnpm --filter @locumfinder/api prisma:generate",
    "db:migrate": "pnpm --filter @locumfinder/api prisma:migrate",
    "db:seed": "pnpm --filter @locumfinder/api prisma:seed"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
